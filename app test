import computer_vision as cv
import math_engine as me
from PIL import Image
import io

# 1. Start the engines
print("🚀 Initializing B-SVaR Integration...")
cv.load_clip_engine()

# 2. Extract a single frame from your new video
# Frame 150 is usually a good spot to check for activity
video_path = "/Users/kevinn.chan/PycharmProjects/DLWeek/assets/IMG_6589.MP4"
frame_bytes = cv.extract_frames(video_path, frame_number=150)

if frame_bytes:
    # 3. Get the Visual Likelihood P(V|T)
    vision_results = cv.calc_clip_risk(frame_bytes)
    likelihood = vision_results["p_vgt"]

    # 4. Get the Contextual Prior and VaR from the Beta Distribution
    # Let's simulate a 'Tense' environment: Night, Rain, High Risk Precinct
    prior, var_threshold = me.monte_carlo_sims(
        time="Night (2 AM - 5 AM)",
        weather="Heavy Rain/Storm/Snow",
        precinct_risks="Low"
    )

    # 5. Bayesian Fusion
    posterior = me.calculate_bayesian_posterior(prior, likelihood)

    print(f"\n--- INTEGRATION REPORT: {video_path} ---")
    print(f"Visual Evidence P(V|T)  : {likelihood:.4f}")
    print(f"Contextual Prior P(T)    : {prior:.4f}")
    print(f"Dynamic VaR Threshold   : {var_threshold:.4f}")
    print(f"FINAL POSTERIOR RISK    : {posterior:.4f}")

    if posterior > var_threshold:
        print("\n🚨 RESULT: BREACH. The evidence warrants an alert even with environmental noise.")
    else:
        print("\n✅ RESULT: SUPPRESSED. The risk is absorbed by the contextual variance.")
else:
    print("❌ Error: Could not extract frame. Check your file path!")
