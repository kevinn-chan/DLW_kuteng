import numpy as np
import torch
import torch.nn.functional as F
from torch.nn.functional import cosine_similarity
from transformers import CLIPProcessor, CLIPModel
from PIL import Image
from io import BytesIO
import logging

logger = logging.getLogger(__name__)

#Setup

threat_anchors = [
    "A violent physical assault or fight between people, or about to happen",
    "A panicked crowd running away from danger",
    "An emergency situation with lives of people are at risk.",
    "A robbery or violent confrontation taking place or about to take place",
    "Someone being or about to be attacked or assaulted",
    "Someone contemplating suicide",
]

safe_anchors= [
    "A normal quiet city street with people walking",
    "Heavy traffic but normal pedestrian conditions",
    "People commuting calmly at a train station",
    "An ordinary busy urban scene with foot traffic",
]

anchors = threat_anchors + safe_anchors
threat_count = len(threat_anchors)
safe_count = len(safe_anchors)

model_id = "openai/clip-vit-base-patch32"

model = None
processor = None
E_text = None
logit_scale = None

def load_clip_engine():
    global model, processor, E_text, logit_scale
    if E_text is not None:
        return #already loaded

    device = "cuda" if torch.cuda.is_available() else "cpu"
    logger.info("Loading" + model_id + "on"+ device)
    model = CLIPModel.from_pretrained(model_id).to(device)
    processor = CLIPProcessor.from_pretrained(model_id)
    model.eval()

    with torch.no_grad():
        #tells pytorch to not build computational graphs
        text_inputs = processor(text = anchors, return_tensors = "pt", padding = True, truncation= True,).to(device)
        #inner text transformer
        text_outputs = model.text_model(input_ids=text_inputs["input_ids"], attention_mask=text_inputs["attention_mask"])

        #manually push the pooled output through the projection layer to get the 512-dim vector
        raw_E_text = model.text_projection(text_outputs.pooler_output)

        #normalise for cos similarity later (optimising for later), result is 512x anchors
        E_text = raw_E_text / raw_E_text.norm(p=2, dim=1, keepdim = True)

        logit_scale = model.logit_scale.exp()

    #log actual temperature value for transparency
    logger.info("CLIP ready, logit_scale = "+ str(round(logit_scale.item(),2)))


#Frame Calculations using LA and Cosine Similarity
def calc_clip_risk(image_input): #image can be PIL image object, file path string or raw JPEG bytes
    if E_text is None:
        raise RuntimeError("Call load_clip_engine() before calculations")

    if isinstance(image_input, bytes):    #image is raw JPEG bytes
        image = Image.open(BytesIO(image_input)).convert("RGB")
    elif isinstance(image_input, str):    #image is file path string
        image = Image.open(image_input).convert("RGB")
    else:
        image = image_input.convert("RGB")

    with torch.no_grad(): #disable gradient tracking
        #encoding image to single 512-dim vector
        img_inputs = processor(images=image, return_tensors="pt").to(E_text.device)

        #run the inner vision transformer manually
        vision_outputs = model.vision_model(pixel_values=img_inputs["pixel_values"])

        v_raw_image = model.visual_projection(vision_outputs.pooler_output)  # Manually push it through the projection layer to get the 512-dim vector

        #normalise vector image for dot product, result is 1x512
        v_image = v_raw_image / v_raw_image.norm(p = 2, dim = 1, keepdim = True)

        #matrix multiplication for cosine similarity score per text anchor, result is 1x anchor, squeeze(0) gives anchor
        cosine_similarity = (v_image @ E_text.T).squeeze(0) # how similar the image is to the anchor

        #higher logit_scale makes the softmax distribution sharper (winner takes more)
        L = logit_scale * cosine_similarity

        #Applying softmax to convert N raw logit scores into N probabilities that sum to 1.0
        prob = F.softmax(L, dim=0).cpu().numpy()

        #raw cosine similarity values bef softmax
        raw_cs = cosine_similarity.cpu().numpy()

    #Probability arrays
    threat_prob = prob[:threat_count]
    safe_probs = prob[threat_count:]

    #Sum of all threat probs, P(V|T), likelihood the visual evidence matches a threat
    p_vgt = float(np.sum(threat_prob))

    top_idx = int(np.argmax(threat_prob)) #threat anchor with highest prob

    #Build dicts
    threat_scores = {} # maps each threat to its softmax probability
    for i in range(threat_count):
        threat_scores[threat_anchors[i]] = float(threat_prob[i])
    safe_scores = {}
    for i in range(safe_count):
        safe_scores[safe_anchors[i]] = float(safe_probs[i])
    cosine_dict = {} # raw pre softmax score for all anchors
    for i in range(len(anchors)):
        cosine_dict[anchors[i]] = float(raw_cs[i]) #key = anchor text, value = cs score

    result = {"p_vgt": p_vgt, "prob": prob.tolist(), "threat_scores": threat_scores, "safe_scores": safe_scores, "top_threat": anchors[top_idx], "top_threat_score": float(threat_prob[top_idx]),
              "cosine_similarity": cosine_dict, "logit_scale": float(logit_scale.item())
              }

    return result


#Parsing in "live video"
def extract_frames(video_path, frame_number = 100): #returnns JPEg bytes
    try:
        import cv2     #opencv handls video file reading
        cap = cv2.VideoCapture(video_path)
        cap.set(cv2.CAP_PROP_POS_FRAMES, frame_number)
        ret, frame = cap.read()
        cap.release()
        if not ret:
            return None
        _, buf = cv2.imencode(".jpg", frame, [cv2.IMWRITE_JPEG_QUALITY, 90])
        return buf.tobytes()
    except ImportError:
        return None


if __name__ == "__main__":
    import sys                              # sys.argv gives us command line arguments
    logging.basicConfig(level=logging.INFO) #info-level log messages

    print("Loading " + model_id + " (first run downloads ~350 MB)...")
    load_clip_engine()                      # load the model and encode all text anchors
    print("Ready.\n")

    # ── HOW TO PASS IN YOUR VIDEO CLIP ───────────────────────────────────────
    #
    #   Option A: pass a video file path and frame number as command line arguments
    #     python vision_engine.py path/to/video.mp4 150
    #
    #   Option B: pass just a video file path (uses frame 100 by default)
    #     python vision_engine.py path/to/video.mp4
    #
    #   Option C: pass an image file path directly
    #     python vision_engine.py path/to/image.jpg
    #
    #   Option D: no arguments -- runs on a synthetic grey image just to test the math
    # ─────────────────────────────────────────────────────────────────────────

    image_input = None                          # will hold whatever image we end up scoring

    if len(sys.argv) >= 2:                      # at least one argument was given
        input_path = sys.argv[1]                # first argument is always the file path

        if input_path.endswith(".mp4") or input_path.endswith(".mov") or input_path.endswith(".avi"):
            # ── VIDEO INPUT ──────────────────────────────────────────────────
            frame_number = 100                          # default frame to extract
            if len(sys.argv) >= 3:                      # if a frame number was also passed
                frame_number = int(sys.argv[2])         # use it instead of the default

            print("Extracting frame " + str(frame_number) + " from: " + input_path)
            image_input = extract_frames(input_path, frame_number)  # returns JPEG bytes

            if image_input is None:                     # extraction failed
                print("ERROR: could not extract frame. Check the file path and frame number.")
                sys.exit(1)                             # stop the program

            print("Frame extracted successfully.\n")

        else:
            # ── IMAGE INPUT ──────────────────────────────────────────────────
            print("Scoring image: " + input_path)
            image_input = input_path                    # pass the path string directly to calc_clip_risk

    else:
        # ── SYNTHETIC FALLBACK ───────────────────────────────────────────────
        print("No file given -- using a synthetic grey image to test the math.\n")
        image_input = Image.new("RGB", (224, 224), color=(73, 109, 137))    # plain grey image

    # Run the full CLIP pipeline on whatever image we loaded
    r = calc_clip_risk(image_input)

    # ── PRINT RESULTS ────────────────────────────────────────────────────────
    print("=" * 64)
    print("  logit_scale (learned temperature) : " + str(round(r["logit_scale"], 4)))
    print("  P(V|T) Aggregate Threat Score     : " + str(round(r["p_vgt"], 4)))
    print("  Top threat anchor                 : " + r["top_threat"])
    print("  Top threat score                  : " + str(round(r["top_threat_score"], 4)))
    print()
    print("  THREAT ANCHORS")
    for text in threat_anchors:                         # loop over threat anchors in order
        prob = r["threat_scores"][text]                 # look up its probability
        bar  = "#" * int(prob * 60)                     # text bar proportional to probability
        print("    " + str(round(prob, 4)) + "  " + bar + "  " + text)
    print()
    print("  SAFE ANCHORS")
    for text in safe_anchors:                           # loop over safe anchors in order
        prob = r["safe_scores"][text]                   # look up its probability
        bar  = "#" * int(prob * 60)                     # text bar proportional to probability
        print("    " + str(round(prob, 4)) + "  " + bar + "  " + text)
    print("=" * 64)
