import streamlit as st
import cv2
import tempfile
import pandas as pd
from PIL import Image

import computer_vision as cv_engine
import math_engine as risk_engine

# --- UI SETUP ---
st.set_page_config(page_title="B-SVaR Traffic Engine", page_icon="🚦", layout="wide")
st.title("🚦B-SVaR: Autonomous Traffic Incident Engine")
st.markdown("Real-time Bayesian fusion of semantic visual telemetry and infrastructural risk.")
st.divider()

if 'history_posterior' not in st.session_state:
    st.session_state.history_posterior = []
if 'history_var' not in st.session_state:
    st.session_state.history_var = []

# --- SIDEBAR: CONTEXTUAL INPUTS ---
st.sidebar.header("🛣️Infrastructure Profile")
road_type = st.sidebar.selectbox("Road Architecture", ["Straight City Road", "High-Speed Highway", "Complex Intersection"], index=0)

st.sidebar.header("🌦️Environmental Macro")
traffic_flow = st.sidebar.selectbox("Traffic Flow State", ["Normal Flow", "Rush Hour (Gridlock)", "Night (Low Visibility)"], index=0)
weather = st.sidebar.selectbox("Surface Conditions", ["Clear/Dry", "Fog/Low Visibility", "Heavy Rain/Wet Asphalt"], index=0)

# --- RUN MATH ENGINE ---
prior_pt, var_threshold = risk_engine.monte_carlo_sims(
    flow=traffic_flow,
    weather=weather,
    road=road_type,
    evidence_power=1.5
)

# --- UI LAYOUT ---
col1, col2 = st.columns([2, 1.2])

with col2:
    st.subheader("📊Quantitative Risk Metrics")
    m1, m2 = st.columns(2)
    m1.metric(label="Contextual Prior $P(T)$", value=f"{prior_pt:.4f}")
    m2.metric(label="95% VaR Threshold", value=f"{var_threshold:.4f}")

    st.markdown("### Live Telemetry")
    status_placeholder = st.empty()
    likelihood_placeholder = st.empty()
    chart_placeholder = st.empty()

with col1:
    st.subheader("📹Live Surveillance Feed")
    video_file = open('whateverviduwant.mp4', 'rb')
    video_bytes = video_file.read()
    stop_button = st.button("🛑Stop Stream")

    if video_file is not None and not stop_button:
        with st.spinner("Initializing CLIP Semantic Engine..."):
            cv_engine.load_clip_engine()
            cv_engine.reset_history()

        tfile = tempfile.NamedTemporaryFile(delete=False)
        tfile.write(video_bytes)
        cap = cv2.VideoCapture(tfile.name)

        st_frame = st.empty()
        frame_count = 0

        st.session_state.history_posterior = []
        st.session_state.history_var = []

        if "gate" not in st.session_state:
            st.session_state.gate = risk_engine.PersistenceGate(consecutive=2)
        st.session_state.gate.reset()

        while cap.isOpened():
            ret, frame = cap.read()
            if not ret or stop_button:
                break

            frame_count += 1
            frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            st_frame.image(frame_rgb, use_container_width=True, channels="RGB")

            # Sample every 10 frames to keep the Streamlit app highly responsive
            if frame_count % 10 == 0:
                pil_img = Image.fromarray(frame_rgb)

                cv_results = cv_engine.calc_clip_risk(pil_img)
                likelihood_pvt = cv_results["p_vgt"]
                posterior_ptv = risk_engine.calculate_bayesian_posterior(prior_pt, likelihood_pvt, evidence_power=1.5)

                st.session_state.history_posterior.append(posterior_ptv)
                st.session_state.history_var.append(var_threshold)

                likelihood_placeholder.info(f"👁️**Smoothed Vision Likelihood $P(V|T)$:** `{likelihood_pvt:.4f}`")

                if st.session_state.gate.update(posterior_ptv, var_threshold):
                    status_placeholder.error(f"🚨**CRASH DETECTED** \n\nPosterior Risk ({posterior_ptv:.4f}) exceeded VaR.")
                else:
                    status_placeholder.success(f"✅**TRAFFIC NORMAL** \n\nPosterior Risk ({posterior_ptv:.4f}) absorbed by context.")

                chart_data = pd.DataFrame({
                    "Live Posterior Risk": st.session_state.history_posterior,
                    "VaR Threshold": st.session_state.history_var
                })
                chart_placeholder.line_chart(chart_data, color=["#FF4B4B", "#1f77b4"])

        cap.release()
